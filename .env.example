# --- Planner ---
# Real Anthropic API key (console.anthropic.com). Required for lib/planner.ts and internal skills.
ANTHROPIC_API_KEY=

# --- Agentic Wallet (identity + treasury) ---
# Orchestra's real EVM address, from `onchainos wallet balance` after `onchainos wallet login`.
ORCHESTRA_AGENTIC_WALLET=0x2f51f4a184486c3dccfffef2ebba448a1a398d77

# --- Inbound x402 gate (app/api/orchestrate) ---
# Apply at https://web3.okx.com/onchainos/dev-portal. Route ships without these
# but withX402() cannot verify/settle inbound payment until they're set.
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# --- X Layer mainnet contract deploy (contracts/OrchestraEscrow.sol) ---
# Never paste this in chat. Fill directly in your local .env only.
# Chain: X Layer mainnet, chainId 196, RPC https://rpc.xlayer.tech
DEPLOYER_PRIVATE_KEY=

# --- OKLink contract verification (optional, for `forge script --verify`) ---
# Apply at https://www.oklink.com/docs/en/#quickstart-guide-getting-started
OKLINK_API_KEY=

# --- Run ledger ---
ORCHESTRA_DB_PATH=./data/orchestra.db

# --- Operator key (manual Mission Control runs, per PRD FR-7 review-week path) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ORCHESTRA_OPERATOR_KEY=
