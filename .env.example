# --- Planner + report synthesis (Groq, free tier) ---
# Real Groq API key (console.groq.com). Required for lib/planner.ts and
# lib/skills/synthesize-report.ts. Uses structured outputs (strict JSON schema)
# on openai/gpt-oss-120b by default -- override the model with GROQ_MODEL.
GROQ_API_KEY=
GROQ_MODEL=

# --- News scan + risk flags (Anthropic, needs the hosted web_search tool) ---
# Real Anthropic API key (console.anthropic.com). Required only for
# lib/skills/news-scan.ts and lib/skills/risk-flags.ts, which need Anthropic's
# hosted web_search tool for real, cited results.
ANTHROPIC_API_KEY=

# --- Agentic Wallet (identity + treasury) ---
# Orchestra's real EVM address, from `onchainos wallet balance` after `onchainos wallet login`.
ORCHESTRA_AGENTIC_WALLET=0x2f51f4a184486c3dccfffef2ebba448a1a398d77

# --- Inbound x402 gate (app/api/orchestrate) ---
# Apply at https://web3.okx.com/onchainos/dev-portal. Route ships without these
# but withX402() cannot verify/settle inbound payment until they're set.
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# --- X Layer mainnet contract deploy (contracts/OrchestraEscrow.sol) ---
# Never paste this in chat. Fill directly in your local .env only.
# Chain: X Layer mainnet, chainId 196, RPC https://rpc.xlayer.tech
# This same key is also the escrow contract's `master` at runtime (whoever
# deploys becomes `master` per the constructor) -- lib/escrow.ts reuses it to
# sign the per-task lock()/settle()/refund() mirror calls, so it must stay
# available to the running service, not just at deploy time.
DEPLOYER_PRIVATE_KEY=

# --- On-chain escrow mirror (lib/escrow.ts, PRD §7.5 Vision Layer) ---
# The deployed OrchestraEscrow address (printed by `forge script script/Deploy.s.sol`).
# Leave unset to skip on-chain mirroring entirely -- the real x402 payment to the
# sub-agent still happens regardless; this only adds a supplementary on-chain receipt.
ORCHESTRA_ESCROW_ADDRESS=
# Per-task mirror value in native OKB wei. Defaults to 0.0001 OKB in code if unset --
# tune this against a real OKB/USD rate to approximate the PRD's "~0.1 USD/task" cap.
ESCROW_MIRROR_VALUE_WEI=

# --- OKLink contract verification (optional, for `forge script --verify`) ---
# Apply at https://www.oklink.com/docs/en/#quickstart-guide-getting-started
OKLINK_API_KEY=

# --- Run ledger ---
ORCHESTRA_DB_PATH=./data/orchestra.db

# --- Operator key (manual Mission Control runs, per PRD FR-7 review-week path) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ORCHESTRA_OPERATOR_KEY=
